# SpinSense Environment Configuration
# Copy this file to .env and customize for your setup
# These variables override settings in config.json

# --- MQTT Broker Configuration ---
# Required for communication with Home Assistant
MQTT_HOST=192.168.1.100
MQTT_PORT=1883
MQTT_USER=spinsense
MQTT_PASSWORD=securepassword
MQTT_ENABLED=true

# --- Audio Configuration ---
# Threshold: RMS volume level that triggers music detection (0.001-0.5)
# Default 0.015 works for most setups, increase for quieter sources
AUDIO_THRESHOLD=0.015

# Sample Length: Duration in seconds to record for Shazam recognition (1.0-30.0)
AUDIO_SAMPLE_LENGTH=5.0

# Sample Rate: Audio sampling rate in Hz (16000, 44100, or 48000)
# Use 48000 for best quality if your USB audio interface supports it
AUDIO_SAMPLE_RATE=48000

# Silence Interval: Seconds of silence before marking record as stopped
SILENCE_INTERVAL=5.0

# Audio Device: Name of the audio input device
# Leave empty to auto-detect USB audio input
# Examples: "USB Audio CODEC", "Microphone", "hw:1,0"
AUDIO_DEVICE=

# Audio Device Index: Numeric index of audio device (0, 1, 2, etc.)
# Only used if AUDIO_DEVICE is not specified
# Leave empty to auto-detect
AUDIO_DEVICE_INDEX=

# --- Logging Configuration ---
# Log level: debug, info, warning, error
LOG_LEVEL=info

# --- Home Assistant Integration Mode ---
# Set to true when running as HA custom integration
# Set to false for standalone Docker container with web UI
HA_INTEGRATION_MODE=false
